class Solution {
public:
    bool isPalindrome(int n) {
        int org = n;
        int rev;
        while(n != 0){
            int d = n % 10;
            
            if(rev >INT_MAX/10 || rev <INT_MIN/10 ){
                return 0;
            }
            rev = rev * 10 +d;
            n=n/10;
        }
         if(org == rev){
            return 1;
         }
         else{
            return 0;
         }
            
    }
};
